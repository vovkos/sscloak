# Shared client values. Copy to local/client.env and fill in the real values.
SS_HOST=<server hostname or IP>
SS_PORT=8443
SS_METHOD=chacha20-ietf-poly1305
SS_PASSWORD=<generated Shadowsocks password>

CK_UID=<generated Cloak UID>
CK_PUBLIC_KEY=<generated Cloak public key>
CK_SERVER_NAME=tile.openstreetmap.org
CK_BROWSER_SIG=chrome
CK_PROXY_METHOD=shadowsocks
CK_ENCRYPTION_METHOD=aes-gcm
CK_TRANSPORT=direct
CK_STREAM_TIMEOUT=300
CK_NUM_CONN=1

# Local listener values normally do not need to change.
SS_LOCAL_SERVER=127.0.0.1
SS_LOCAL_SERVER_PORT=16789
SS_LOCAL_ADDRESS=127.0.0.1
SS_LOCAL_PORT=10810
SS_TIMEOUT=60
